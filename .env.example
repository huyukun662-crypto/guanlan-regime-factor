# Copy to .env and fill in. .env is gitignored — never commit real keys.

# === Tushare Pro token (REQUIRED — primary data source) ===
# Get one free at https://tushare.pro/register
TUSHARE_TOKEN=

# === LLM provider for the dashboard's live AI advisor (OPTIONAL) ===
# Without any key, the pipeline + dashboard still work; the AI chat just
# degrades to the deterministic baseline advice line.
#
# Pick ONE of the setups below (uncomment / fill in):
#
# A) Anthropic Claude (default — backward compatible)
ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8                   # optional override
#
# B) OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
#
# C) OpenAI-compatible providers (DeepSeek / Moonshot Kimi / Zhipu / Qwen / Ollama …)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...                          # your provider's key
# LLM_BASE_URL=https://api.deepseek.com       # DeepSeek
# # LLM_BASE_URL=https://api.moonshot.cn/v1     # Moonshot Kimi
# # LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4   # Zhipu (GLM)
# # LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # 通义千问
# # LLM_BASE_URL=http://localhost:11434/v1     # Ollama (local)
# LLM_MODEL=deepseek-chat                     # provider-specific model id
