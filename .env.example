# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Tushare Pro token (REQUIRED — primary data source).
# Get one free at https://tushare.pro/register
TUSHARE_TOKEN=

# Anthropic API key (OPTIONAL — only the live dashboard chat needs it).
# Without it, the pipeline + dashboard still work; chat degrades to the
# deterministic advice line. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=
