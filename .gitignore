# Secrets — NEVER commit
.env
*.key
*.pem
credentials.json

# Data cache (re-fetchable via Tushare; kept out of git to stay light)
data/cache/

# Scheduled-refresh logs
logs/
outputs/*.log

# Machine-local Claude Code state (session logs + local permission overrides)
.claude/logs/
.claude/settings.local.json

# Scratch / temp
temp/

# Build artifact: the reusable package is produced via `git archive`, not committed
*.zip

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
